package com.carsharing.services;

import com.carsharing.BasePropertyTest;
import com.carsharing.entities.Payment;
import com.carsharing.entities.Ride;
import com.carsharing.entities.User;
import com.carsharing.entities.Vehicle;
import net.jqwik.api.*;
import net.jqwik.api.lifecycle.BeforeTry;
import net.jqwik.spring.JqwikSpringSupport;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.boot.test.context.SpringBootTest;
import org.springframework.test.context.TestPropertySource;
import org.springframework.transaction.annotation.Transactional;

import java.math.BigDecimal;
import java.util.List;
import java.util.Optional;
import java.util.UUID;

import static org.assertj.core.api.Assertions.assertThat;

/**
 * Property tests for PaymentService
 * 
 * **Feature: carsharing-data-lifecycle-management, Property 6: Payment Creation Consistency**
 * *For any* completed ride, a corresponding payment record should be created with the correct 
 * amount and linked to both the ride and user.
 * **Validates: Requirements 2.4**
 */
@JqwikSpringSupport
@SpringBootTest
@TestPropertySource(properties = {
    "spring.datasource.url=jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1",
    "spring.datasource.driver-class-name=org.h2.Driver",
    "spring.jpa.hibernate.ddl-auto=create-drop"
})
@Transactional
public class PaymentServicePropertyTest extends BasePropertyTest {

    @Autowired
    private PaymentService paymentService;
    
    @Autowired
    private RideService rideService;
    
    @Autowired
    private UserService userService;
    
    @Autowired
    private VehicleService vehicleService;
    
    private UUID testUserId;
    private UUID testVehicleId;
    private UUID testRideId;
    private String testPassword = "TestPassword123!";
    private BigDecimal testRideCost;
    
    @BeforeTry
    void setup() {
        // Create test user
        User user = userService.registerUser(
            "test" + UUID.randomUUID() + "@example.com",
            "+1234567890",
            "Test",
            "User",
            testPassword
        );
        testUserId = user.getId();
        
        // Create test vehicle
        Vehicle vehicle = vehicleService.addVehicle(
            "Toyota",
            "Camry",
            "ABC" + UUID.randomUUID().toString().substring(0, 3),
            "red"
        );
        testVehicleId = vehicle.getId();
        
        // Create and complete a test ride
        String startLocation = "{\"latitude\": 55.7558, \"longitude\": 37.6173}";
        Ride ride = rideService.startRide(testUserId, testVehicleId, startLocation);
        testRideId = ride.getId();
        
        // Wait a moment to ensure ride has duration
        try { Thread.sleep(100); } catch (InterruptedException e) {}
        
        String endLocation = "{\"latitude\": 55.7600, \"longitude\": 37.6200}";
        Ride completedRide = rideService.endRide(testRideId, endLocation);
        testRideCost = completedRide.getTotalCost();
    }
    
    /**
     * Property 6: Payment Creation Consistency
     * Validates: Requirements 2.4
     */
    @Property(tries = 50)
    void paymentCreationConsistency(@ForAll("paymentMethods") String paymentMethod) {
        // Given a completed ride and valid payment method
        assertThat(paymentMethod).isNotBlank();
        
        // When creating a payment for the ride
        Payment payment = paymentService.createPaymentForRide(testRideId, paymentMethod);
        
        // Then the payment should be created with correct information
        assertThat(payment).isNotNull();
        assertThat(payment.getId()).isNotNull();
        assertThat(payment.getRideId()).isEqualTo(testRideId);
        assertThat(payment.getUserId()).isEqualTo(testUserId);
        assertThat(payment.getAmount()).isEqualTo(testRideCost);
        assertThat(payment.getCurrency()).isEqualTo("RUB");
        assertThat(payment.getPaymentMethod()).isEqualTo(paymentMethod);
        assertThat(payment.getStatus()).isEqualTo("pending");
        assertThat(payment.isPending()).isTrue();
        assertThat(payment.getCreatedAt()).isNotNull();
        
        // And the payment should be retrievable by ID
        Optional<Payment> retrievedPayment = paymentService.getPaymentById(payment.getId());
        assertThat(retrievedPayment).isPresent();
        assertThat(retrievedPayment.get().getRideId()).isEqualTo(testRideId);
        assertThat(retrievedPayment.get().getUserId()).isEqualTo(testUserId);
        assertThat(retrievedPayment.get().getAmount()).isEqualTo(testRideCost);
        
        // And the payment should be in the user's payment list
        List<Payment> userPayments = paymentService.getPaymentsByUserId(testUserId);
        assertThat(userPayments).anyMatch(p -> p.getId().equals(payment.getId()));
        
        // And the payment should be in the ride's payment list
        List<Payment> ridePayments = paymentService.getPaymentsByRideId(testRideId);
        assertThat(ridePayments).anyMatch(p -> p.getId().equals(payment.getId()));
    }
    
    /**
     * Property: Payment Completion
     */
    @Property(tries = 50)
    void paymentCompletion(
            @ForAll("paymentMethods") String paymentMethod,
            @ForAll String transactionId) {
        
        // Given a created payment
        Payment payment = paymentService.createPaymentForRide(testRideId, paymentMethod);
        UUID paymentId = payment.getId();
        
        // When completing the payment
        Payment completedPayment = paymentService.completePayment(paymentId, transactionId);
        
        // Then the payment should be marked as completed
        assertThat(completedPayment.getStatus()).isEqualTo("completed");
        assertThat(completedPayment.getTransactionId()).isEqualTo(transactionId);
        assertThat(completedPayment.getCompletedAt()).isNotNull();
        assertThat(completedPayment.isCompleted()).isTrue();
        
        // And the payment should be in completed payments list
        List<Payment> completedPayments = paymentService.getPaymentsByStatus("completed");
        assertThat(completedPayments).anyMatch(p -> p.getId().equals(paymentId));
    }
    
    /**
     * Property: Payment Failure
     */
    @Property(tries = 50)
    void paymentFailure(@ForAll("paymentMethods") String paymentMethod) {
        // Given a created payment
        Payment payment = paymentService.createPaymentForRide(testRideId, paymentMethod);
        UUID paymentId = payment.getId();
        
        // When failing the payment
        Payment failedPayment = paymentService.failPayment(paymentId);
        
        // Then the payment should be marked as failed
        assertThat(failedPayment.getStatus()).isEqualTo("failed");
        
        // And the payment should be in failed payments list
        List<Payment> failedPayments = paymentService.getPaymentsByStatus("failed");
        assertThat(failedPayments).anyMatch(p -> p.getId().equals(paymentId));
    }
    
    /**
     * Property: Payment Refund
     */
    @Property(tries = 50)
    void paymentRefund(
            @ForAll("paymentMethods") String paymentMethod,
            @ForAll String transactionId) {
        
        // Given a completed payment
        Payment payment = paymentService.createPaymentForRide(testRideId, paymentMethod);
        Payment completedPayment = paymentService.completePayment(payment.getId(), transactionId);
        UUID paymentId = completedPayment.getId();
        
        // When refunding the payment
        Payment refundedPayment = paymentService.refundPayment(paymentId);
        
        // Then the payment should be marked as refunded
        assertThat(refundedPayment.getStatus()).isEqualTo("refunded");
        
        // And the payment should be in refunded payments list
        List<Payment> refundedPayments = paymentService.getPaymentsByStatus("refunded");
        assertThat(refundedPayments).anyMatch(p -> p.getId().equals(paymentId));
    }
    
    /**
     * Property: Revenue Calculation
     */
    @Property(tries = 30)
    void revenueCalculation(@ForAll("paymentMethods") String paymentMethod) {
        // Given some completed payments
        int numPayments = 3;
        BigDecimal totalExpectedRevenue = BigDecimal.ZERO;
        
        for (int i = 0; i < numPayments; i++) {
            // Create and complete a ride
            UUID userId = createTestUser();
            UUID vehicleId = createTestVehicle();
            UUID rideId = createAndCompleteRide(userId, vehicleId);
            
            // Get ride cost
            Optional<Ride> ride = rideService.getRideById(rideId);
            BigDecimal rideCost = ride.map(Ride::getTotalCost).orElse(BigDecimal.ZERO);
            
            // Create and complete payment
            Payment payment = paymentService.createPaymentForRide(rideId, paymentMethod);
            paymentService.completePayment(payment.getId(), "txn_" + UUID.randomUUID());
            
            totalExpectedRevenue = totalExpectedRevenue.add(rideCost);
        }
        
        // When getting total revenue
        BigDecimal totalRevenue = paymentService.getTotalRevenue();
        
        // Then revenue should include all completed payments
        assertThat(totalRevenue).isNotNull();
        assertThat(totalRevenue.compareTo(BigDecimal.ZERO)).isGreaterThan(0);
        
        // Note: In a real test, we would compare exact amounts, but due to 
        // transaction isolation, we can't guarantee all payments are in the same transaction
    }
    
    /**
     * Property: Payment Uniqueness per Ride
     */
    @Property(tries = 30)
    void paymentUniquenessPerRide(@ForAll("paymentMethods") String paymentMethod) {
        // Given a payment already exists for a ride
        Payment firstPayment = paymentService.createPaymentForRide(testRideId, paymentMethod);
        
        // When trying to create another payment for the same ride
        try {
            paymentService.createPaymentForRide(testRideId, paymentMethod);
            
            // Then it should throw an exception
            assertThat(false).isTrue(); // Force failure if we reach here
        } catch (IllegalStateException e) {
            // Expected: payment already exists
            assertThat(e.getMessage()).contains("already exists");
        }
    }
    
    /**
     * Property: Payment Status Transitions
     */
    @Property(tries = 50)
    void paymentStatusTransitions(
            @ForAll("paymentMethods") String paymentMethod,
            @ForAll String transactionId) {
        
        // Given a created payment
        Payment payment = paymentService.createPaymentForRide(testRideId, paymentMethod);
        UUID paymentId = payment.getId();
        
        // When transitioning through statuses
        assertThat(payment.isPending()).isTrue();
        
        // Pending -> Completed
        Payment completed = paymentService.completePayment(paymentId, transactionId);
        assertThat(completed.isCompleted()).isTrue();
        
        // Completed -> Refunded
        Payment refunded = paymentService.refundPayment(paymentId);
        assertThat(refunded.getStatus()).isEqualTo("refunded");
        
        // Refunded payments should not be able to be completed again
        try {
            paymentService.completePayment(paymentId, "another_txn");
            assertThat(false).isTrue(); // Force failure if we reach here
        } catch (IllegalStateException e) {
            assertThat(e.getMessage()).contains("not pending");
        }
    }
    
    // Helper methods
    
    private UUID createTestUser() {
        User user = userService.registerUser(
            "test" + UUID.randomUUID() + "@example.com",
            "+1234567890",
            "Test",
            "User",
            testPassword
        );
        return user.getId();
    }
    
    private UUID createTestVehicle() {
        Vehicle vehicle = vehicleService.addVehicle(
            "Toyota",
            "Camry",
            "XYZ" + UUID.randomUUID().toString().substring(0, 3),
            "blue"
        );
        return vehicle.getId();
    }
    
    private UUID createAndCompleteRide(UUID userId, UUID vehicleId) {
        String startLocation = "{\"latitude\": 55.7558, \"longitude\": 37.6173}";
        Ride ride = rideService.startRide(userId, vehicleId, startLocation);
        
        try { Thread.sleep(10); } catch (InterruptedException e) {}
        
        String endLocation = "{\"latitude\": 55.7600, \"longitude\": 37.6200}";
        return rideService.endRide(ride.getId(), endLocation).getId();
    }
}